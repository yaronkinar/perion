{
  "name": "perion-rbac-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:report": "vitest run --reporter=json --outputFile=./test-report.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "e2e": "playwright test",
    "demo:video": "playwright test --config=playwright.demo.config.ts",
    "lint": "eslint \"src/**/*.{ts,vue}\""
  },
  "dependencies": {
    "@vee-validate/zod": "^4.15.1",
    "axios": "^1.7.7",
    "pinia": "^2.2.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.10",
    "vue-router": "^4.4.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@storybook/addon-a11y": "^8.3.4",
    "@storybook/addon-essentials": "^8.3.4",
    "@storybook/blocks": "^8.3.4",
    "@storybook/test": "^8.3.4",
    "@storybook/vue3": "^8.3.4",
    "@storybook/vue3-vite": "^8.3.4",
    "@types/node": "^20.16.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.28.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "storybook": "^8.3.4",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.1",
    "vue-tsc": "^2.1.6"
  }
}
